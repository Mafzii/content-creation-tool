# ── Required ─────────────────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in your values.
# The backend/ directory is the working directory for the Go server.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
DATABASE_PATH=data/app.db

# ── LLM (configure via the Settings tab in the UI too) ───────────────────────
# Supported providers: gemini | claude | openai
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# LLM_API_KEY=your-api-key-here

# ── Docker / deployment ───────────────────────────────────────────────────────
# Used by docker-compose.prod.yml
# HOST_IP=0.0.0.0      # bind all interfaces (default); set to Tailscale IP to restrict
# DOCKER_IMAGE=content-creation-tool:latest
